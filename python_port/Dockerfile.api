FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN pip install --no-cache-dir \
    "fastapi>=0.115.0" \
    "uvicorn[standard]>=0.30.0" \
    "redis>=5.0.0"

COPY game4s_py ./game4s_py

EXPOSE 8000

CMD ["uvicorn", "game4s_py.server.main:app", "--host", "0.0.0.0", "--port", "8000"]
